	<queryString language="SQL">
		<![CDATA[SELECT 
m.nim,
m.nama,
m.semester,
m.kelas,
k.kodeMataKuliah,
k.namaMataKuliah,
k.jumlahSks,
n.nilaiTugas,
n.nilaiUts,
n.nilaiUas

FROM dbaplikasipenilaianmahasiswa.tbnilai n

JOIN dbaplikasipenilaianmahasiswa.tbmahasiswa m
ON n.nim = m.nim

JOIN dbaplikasipenilaianmahasiswa.tbmatakuliah k
ON n.kodeMataKuliah = k.kodeMataKuliah]]>
	</queryString>
